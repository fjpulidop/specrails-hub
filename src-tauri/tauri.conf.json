{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpecRails Hub",
  "version": "../package.json",
  "identifier": "sh.specrails.hub",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:4201",
    "beforeBundleCommand": "node scripts/fix-desktop-bundle.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "SpecRails Hub",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "center": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/specrails-server"],
    "resources": {
      "binaries/better_sqlite3.node": "better_sqlite3.node",
      "binaries/pty.node": "pty.node"
    },
    "macOS": {
      "entitlements": "./entitlements.plist"
    }
  }
}
