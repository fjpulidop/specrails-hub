{
  "name": "specrails-hub",
  "version": "1.44.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fjpulidop/specrails-hub.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "specrails-hub": "cli/dist/specrails-hub.js"
  },
  "files": [
    "cli/dist",
    "server/dist",
    "client/dist",
    "docs",
    ".claude/commands/specrails"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "cd client && npm run dev",
    "dev:desktop": "tauri dev",
    "build:server": "node -e \"require('fs').rmSync('server/dist',{recursive:true,force:true})\" && tsc --project tsconfig.json",
    "build:cli": "tsc --project tsconfig.cli.json",
    "build": "npm run build:server && cd client && npm run build && cd .. && npm run build:cli",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "build:desktop": "npm run build:server && cd client && npm run build && cd .. && npm run build:sidecar && tauri build",
    "generate-icons": "tauri icon src-tauri/icons/icon.svg",
    "typecheck": "tsc --noEmit && cd client && tsc --noEmit",
    "check-core-compat": "tsx scripts/check-core-compat.ts",
    "test": "vitest run && tsx scripts/check-core-compat.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:client": "cd client && npx vitest run",
    "test:all": "vitest run && cd client && npx vitest run",
    "ci": "npm run typecheck && npm test && npm run test:coverage && cd client && npm run test:coverage"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "ajv": "^8.17.1",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "cross-spawn": "^7.0.6",
    "diff": "^9.0.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "node-pty": "^1.0.0",
    "pdf-parse": "^2.4.5",
    "read-excel-file": "^9.0.6",
    "tree-kill": "^1.2.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/chokidar": "^1.7.5",
    "@types/cross-spawn": "^6.0.6",
    "@types/diff": "^7.0.2",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
