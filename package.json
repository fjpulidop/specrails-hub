{
  "name": "specrails-hub",
  "version": "0.1.2",
  "description": "Local dashboard and CLI for managing multiple specrails projects from a single interface",
  "keywords": [
    "specrails",
    "claude",
    "ai",
    "pipeline",
    "dashboard",
    "cli"
  ],
  "author": "fjpulidop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fjpulidop/specrails-hub.git"
  },
  "homepage": "https://github.com/fjpulidop/specrails-hub#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "cli/dist",
    "dist/server",
    "client/dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "specrails-hub": "cli/dist/srm.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build:server": "tsc",
    "build:cli": "tsc --project tsconfig.cli.json",
    "build": "cd client && npm run build && cd .. && npm run build:server && npm run build:cli",
    "typecheck": "tsc --noEmit && cd client && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "better-sqlite3": "^12.8.0",
    "express": "^4.18.0",
    "tree-kill": "^1.2.2",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^2.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "concurrently": "^8.2.0",
    "supertest": "^6.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
